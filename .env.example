# SkyHub Configuration Template
# Copy this to .env and fill in your values

# Server Configuration
SKYHUB_STORAGE_ROOT=./storage
SKYHUB_STORAGE_ROOT=./storage
SKYHUB_DEBUG=True

# Database - SQLite (default)
SKYHUB_DATABASE_URL=sqlite:///./storage/db/skyhub.db

# Database - PostgreSQL (external)
# SKYHUB_DATABASE_URL=postgresql://user:password@localhost:5432/skyhub

# Database - MySQL (external)
# SKYHUB_DATABASE_URL=mysql+pymysql://user:password@localhost:3306/skyhub

# Observer Location (for sunrise/sunset calculation)
# Default: Vienna, Austria
SKYHUB_LATITUDE=48.2082
SKYHUB_LONGITUDE=16.3738

# For different locations:
# Berlin: 52.52, 13.40
# London: 51.51, -0.13
# New York: 40.71, -74.01
# Sydney: -33.87, 151.21
